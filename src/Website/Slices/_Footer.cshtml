@{
    var options = Options.Value;
    var repository = options.Metadata?.Repository;
    var timestamp = GitMetadata.Timestamp.ToString("u", CultureInfo.InvariantCulture);
}
<hr />
<footer>
    <p>
        &copy; @(options.Metadata?.Author?.Name) @(DateTimeOffset.UtcNow.Year) |
        Built from
        <a id="link-git-commit" href="@(repository)/commit/@(GitMetadata.Commit)" title="View commit @(GitMetadata.Commit) on GitHub">
            @(GitMetadata.Commit[..7])
        </a>
        on
        <a id="link-git-branch" href="@(repository)/tree/@(GitMetadata.Branch)" title="View branch @(GitMetadata.Branch) on GitHub">
            @(GitMetadata.Branch)
        </a>
        by
        <a href="@(repository)/actions/runs/@(GitMetadata.DeployId)" title="View deployment on GitHub">
            GitHub
        </a>
        <span id="build-date" class="d-none d-sm-inline" data-format="YYYY-MM-DD HH:mm Z" data-timestamp="@(timestamp)" title="@(timestamp)"></span>
    </p>
</footer>
